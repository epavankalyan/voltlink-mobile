{
    "cli": {
        "version": ">= 16.0.0"
    },
    "build": {
        "development": {
            "developmentClient": true,
            "distribution": "internal",
            "android": {
                "buildType": "apk"
            },
            "env": {
                "EXPO_PUBLIC_API_URL": "https://voltlink-be.coffeebeans.io/api/v1",
                "EXPO_PUBLIC_API_TIMEOUT": "10000",
                "EXPO_PUBLIC_DEFAULT_FLEET_ID": "FLEET001",
                "EXPO_PUBLIC_DEFAULT_USER_ID": "11"
            }
        },
        "preview": {
            "distribution": "internal",
            "android": {
                "buildType": "apk"
            },
            "env": {
                "EXPO_PUBLIC_API_URL": "https://voltlink-be.coffeebeans.io/api/v1",
                "EXPO_PUBLIC_API_TIMEOUT": "10000",
                "EXPO_PUBLIC_DEFAULT_FLEET_ID": "FLEET001",
                "EXPO_PUBLIC_DEFAULT_USER_ID": "11"
            }
        },
        "production": {
            "android": {
                "buildType": "app-bundle"
            }
        }
    },
    "submit": {
        "production": {}
    }
}